# ============ Node.js Configuration =====
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ============ Firebase Configuration =====
# URL de la base de datos Firestore
# Formato: https://tu-proyecto.firebaseio.com
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com

# Ruta al archivo de credenciales de Firebase (por defecto: serviceAccountKey.json)
# Este archivo se descarga desde Firebase Console
FIREBASE_CREDENTIALS_FILE=serviceAccountKey.json

# ============ Omada Cloud Configuration =====
# Para Omada Cloud (usa1-omada-cloud.tplinkcloud.com)
OMADA_CONTROLLER_IP=use1-omada-cloud.tplinkcloud.com
OMADA_CONTROLLER_PORT=443
OMADA_CONTROLLER_ID=your-controller-id-here
OMADA_USERNAME=operator1
OMADA_PASSWORD=your-secure-password
OMADA_AUTH_DURATION=3600000

# ============ Omada Local (Opcional) =====
# Descomentar si usas controlador local en lugar de Cloud
# OMADA_CONTROLLER_IP=192.168.1.100
# OMADA_CONTROLLER_PORT=8043
# OMADA_CONTROLLER_ID=your-local-controller-id

