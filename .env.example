# Puerto donde corre el servidor (opcional, por defecto 3000)
PORT=3000

# Configuración de Firebase
# URL de la base de datos Firestore (sin barra final)
# Formato: https://tu-proyecto.firebaseio.com
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com

# Ruta al archivo de credenciales de Firebase (por defecto: serviceAccountKey.json)
# Este archivo se descarga desde Firebase Console
FIREBASE_CREDENTIALS_FILE=serviceAccountKey.json

# Ambiente (development o production)
NODE_ENV=development
